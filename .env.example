# Скопируйте в .env и заполните. docker compose читает этот файл для подстановки.
# JWT_SECRET обязателен; остальное имеет dev-дефолты в docker-compose.yml.

# Подпись JWT — сгенерируйте: openssl rand -base64 48
JWT_SECRET=

# Мастер-ключ шифрования ключей (KEK). Для прода ОБЯЗАТЕЛЬНО задать своим:
KEK=dev-kek

# Пароли ролей БД (прод — задать своими)
POSTGRES_PASSWORD=secret
APP_DB_PASSWORD=app
RESEARCH_PASSWORD=research

# Gemini (мультимодальный разбор документов и ИИ-оценка). Пусто -> детерм. заглушка.
GOOGLE_API_KEY=

# --- Прод-почта (в compose локально стоит Mailpit) ---
# Для реальной доставки укажите релей у сервисов api/worker в docker-compose.yml:
#   SMTP_HOST=smtp.example.com  SMTP_PORT=587  SMTP_STARTTLS=true
#   SMTP_USER=...  SMTP_PASSWORD=...  MAIL_FROM=noreply@yourdomain
